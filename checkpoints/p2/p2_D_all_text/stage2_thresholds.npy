=0.7659  (751.7s)\n09:34:57  INFO        [Epoch 6] step 50/162  loss=0.2331\n09:37:47  INFO        [Epoch 6] step 100/162  loss=0.2368\n09:40:37  INFO        [Epoch 6] step 150/162  loss=0.2364\n09:44:41  INFO        ↑ New best multilabel/macro_f1=0.7668  (saved)\n09:44:41  INFO      [Epoch 6/7] train_loss=0.2397  val_loss=0.3030  multilabel/macro_f1=0.7668  (753.9s)\n09:47:32  INFO        [Epoch 7] step 50/162  loss=0.2353\n09:50:21  INFO        [Epoch 7] step 100/162  loss=0.2372\n09:53:11  INFO        [Epoch 7] step 150/162  loss=0.2333\n09:57:14  INFO      [Epoch 7/7] train_loss=0.2346  val_loss=0.3029  multilabel/macro_f1=0.7661  (752.3s)\n09:57:14  INFO      [P2-D] Calibrating per-category thresholds on val set...\n09:57:14  INFO      [P7 Calibration] Racist: best_threshold=0.50  F1=0.9235\n09:57:14  INFO      [P7 Calibration] Sexist: best_threshold=0.80  F1=0.7427\n09:57:14  INFO      [P7 Calibration] Homophobe: best_threshold=0.80  F1=0.9065\n09:57:14  INFO      [P7 Calibration] Religion: best_threshold=0.80  F1=0.6667\n09:57:14  INFO      [P7 Calibration] OtherHate: best_threshold=0.70  F1=0.8029\n09:57:14  INFO      [P2-D] Thresholds: {'Racist': 0.5000000000000001, 'Sexist': 0.8000000000000002, 'Homophobe': 0.8000000000000002, 'Religion': 0.8000000000000002, 'OtherHate': 0.7000000000000002}\n09:57:14  INFO      [P2-D] Calibrated multilabel macro_f1=0.8085\n09:57:14  INFO      [P2] Done. Results → /kaggle/working/Memes_Vibe_Classifier/results/p2/p2_D_all_text\n","output_type":"stream"},{"name":"stdout","text":"\n============================================================\nP2-D [all_text] — DONE\n============================================================\n","output_type":"stream"}],"execution_count":11},{"id":"e143287a-a9e4-4c4a-981d-1b31603d71e9","cell_type":"markdown","source":"## 📊 8. Results Summary","metadata":{}},{"id":"dbe6561b-6558-4f1a-94a4-da8c86e80869","cell_type":"code","source":"import json\n\nprint(\"=\" * 60)\nprint(f\"P2-{config.variation} [{config.text_mode}] — Results\")\nprint(\"=\" * 60)\n\n# Stage 1\nif \"stage1\" in all_metrics:\n    s1 = all_metrics[\"stage1\"]\n    print(f\"\\n  Stage 1:\")\n    print(f\"    Best Macro F1 : {s1.get('best', 0):.4f}\")\n\n# Stage 2\nif \"stage2\" in all_metrics:\n    s2 = all_metrics[\"stage2\"]\n    print(f\"\\n  Stage 2 (raw thresholds):\")\n    print(f\"    Best Macro F1 : {s2.get('best', 0):.4f}\")\n\n# Stage 2 calibrated\nif \"stage2_calibrated\" in all_metrics:\n    cal = all_metrics[\"stage2_calibrated\"]\n    print(f\"\\n  Stage 2 (calibrated thresholds):\")\n    print(f\"    Micro F1      : {cal.get('multilabel/micro_f1', 0):.4f}\")\n    print(f\"    Macro F1      : {cal.get('multilabel/macro_f1', 0):.4f}\")\n    print(f\"    Sample F1     : {cal.get('multilabel/sample_f1', 0):.4f}\")\n    print(f\"    Hamming Loss  : {cal.get('multilabel/hamming_loss', 0):.4f}\")\n    print(f\"    Exact Match   : {cal.get('multilabel/exact_match', 0):.4f}\")\n    print(f\"    Jaccard       : {cal.get('multilabel/jaccard', 0):.4f}\")\n    \n    print(f\"\\n  Per-class F1:\")\n    from src.p2.dataset import HATE_CAT_NAMES\n    for name in HATE_CAT_NAMES:\n        f1 = cal.get(f\"multilabel/{name}/f1\", 0)\n        print(f\"    {name:<15}: {f1:.4f}\")\n\n# Thresholds\nif \"thresholds\" in all_metrics:\n    print(f\"\\n  Calibrated thresholds:\")\n    from src.p2.dataset import HATE_CAT_NAMES\n    for name, t in zip(HATE_CAT_NAMES, all_metrics[\"thresholds\"]):\n        print(f\"    {name:<15}: {t:.2f}\")\n\n# Pipeline\nif \"pipeline\" in all_metrics:\n    pip = all_metrics[\"pipeline\"]\n    print(f\"\\n  Pipeline (end-to-end):\")\n    print(f\"    S1 recall (hateful) : {pip.get('pipeline/s1_recall_hate', 0):.4f}\")\n    print(f\"    S2 macro F1         : {pip.get('pipeline/s2_macro_f1', 0):.4f}\")\n    print(f\"    Composite (S1×S2)   : {pip.get('pipeline/composite', 0):.4f}\")\n\nprint(\"=\" * 60)\nprint(f\"\\nFull metrics saved to: {config.results_run_dir / 'metrics.json'}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-17T09:58:56.691139Z","iopub.execute_input":"2026-05-17T09:58:56.691666Z","iopub.status.idle":"2026-05-17T09:58:56.702135Z","shell.execute_reply.started":"2026-05-17T09:58:56.691620Z","shell.execute_reply":"2026-05-17T09:58:56.701228Z"}},"outputs":[{"name":"stdout","text":"============================================================\nP2-D [all_text] — Results\n============================================================\n\n  Stage 1:\n    Best Macro F1 : 0.6590\n\n  Stage 2 (raw thresholds):\n    Best Macro F1 : 0.7668\n\n  Stage 2 (calibrated thresholds):\n    Micro F1      : 0.8666\n    Macro F1      : 0.8085\n    Sample F1     : 0.8524\n    Hamming Loss  : 0.0532\n    Exact Match   : 0.8304\n    Jaccard       : 0.8464\n\n  Per-class F1:\n    Racist         : 0.9235\n    Sexist         : 0.7427\n    Homophobe      : 0.9065\n    Religion       : 0.6667\n    OtherHate      : 0.8029\n\n  Calibrated thresholds:\n    Racist         : 0.50\n    Sexist         : 0.80\n    Homophobe      : 0.80\n    Religion       : 0.80\n    OtherHate      : 0.70\n\n  Pipeline (end-to-end):\n    S1 recall (hateful) : 0.6061\n    S2 macro F1         : 0.8085\n    Composite (S1×S2)   : 0.4900\n============================================================\n\nFull metrics saved to: /kaggle/working/Memes_Vibe_Classifier/results/p2/p2_D_all_text/metrics.json\n","output_type":"stream"}],"execution_count":12},{"id":"d379597a-07a3-4505-b33b-db296a5715ae","cell_type":"markdown","source":"## 📋 9. Ablation Comparison Table","metadata":{}},{"id":"e13ad2a9-c096-4fb4-a279-4a2aef22cc00","cell_type":"code","source":"# Aggregates metrics from all completed runs into a comparison table\nimport json\nfrom pathlib import Path\n\nresults_base = Path(config.results_dir)\nrows = []\n\nfor variation in [\"A\", \"B\", \"C\", \"D\"]:\n    for text_mode in [\"tweet_ocr\", \"all_text\"]:\n        run_dir = results_base / f\"p2_{variation}_{text_mode}\"\n        mfile = run_dir / \"metrics.json\"\n        if not mfile.exists():\n            continue\n        with open(mfile) as f:\n            m = json.load(f)\n        \n        row = {\n            \"Variation\": f\"P2-{variation}\",\n            \"Text Mode\": text_mode,\n            \"S1 Macro F1\": f\"{m.get('stage1', {}).get('best', 0):.4f}\" if \"stage1\" in m else \"-\",\n        }\n        \n        if \"stage2_calibrated\" in m:\n            cal = m[\"stage2_calibrated\"]\n            row[\"S2 Macro F1\"] = f\"{cal.get('multilabel/macro_f1', 0):.4f}\"\n            row[\"S2 Micro F1\"] = f\"{cal.get('multilabel/micro_f1', 0):.4f}\"\n            row[\"Hamming\"]     = f\"{cal.get('multilabel/hamming_loss', 0):.4f}\"\n        elif \"stage2\" in m:\n            row[\"S2 Macro F1\"] = f\"{m['stage2'].get('best', 0):.4f}\"\n            row[\"S2 Micro F1\"] = \"-\"\n            row[\"Hamming\"]     = \"-\"\n        else:\n            row[\"S2 Macro F1\"] = \"-\"\n            row[\"S2 Micro F1\"] = \"-\"\n            row[\"Hamming\"]     = \"-\"\n        \n        if \"pipeline\" in m:\n            row[\"E2E Composite\"] = f\"{m['pipeline'].get('pipeline/composite', 0):.4f}\"\n        else:\n            row[\"E2E Composite\"] = \"-\"\n        \n        rows.append(row)\n\nif not rows:\n    print(\"No completed runs found yet. Run training first.\")\nelse:\n    # Print table\n    cols = [\"Variation\", \"Text Mode\", \"S1 Macro F1\", \"S2 Macro F1\", \"S2 Micro F1\", \"Hamming\", \"E2E Composite\"]\n    widths = {c: max(len(c), max(len(str(r.get(c, \"-\"))) for r in rows)) for c in cols}\n    \n    header = \"  \".join(c.ljust(widths[c]) for c in cols)\n    sep = \"  \".join(\"-\" * widths[c] for c in cols)\n    print(header)\n    print(sep)\n    for r in rows:\n        print(\"  \".join(str(r.get(c, \"-\")).ljust(widths[c]) for c in cols))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-17T09:59:01.295806Z","iopub.execute_input":"2026-05-17T09:59:01.296548Z","iopub.status.idle":"2026-05-17T09:59:01.307216Z","shell.execute_reply.started":"2026-05-17T09:59:01.296516Z","shell.execute_reply":"2026-05-17T09:59:01.306552Z"}},"outputs":[{"name":"stdout","text":"Variation  Text Mode  S1 Macro F1  S2 Macro F1  S2 Micro F1  Hamming  E2E Composite\n---------  ---------  -----------  -----------  -----------  -------  -------------\nP2-D       all_text   0.6590       0.8085       0.8666       0.0532   0.4900       \n","output_type":"stream"}],"execution_count":13}]}